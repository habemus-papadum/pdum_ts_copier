# Publish auth is NOT stored here. CI writes a throwaway
# //registry.npmjs.org/:_authToken=... file at publish time (see
# .github/workflows/release.yml); it is never committed.
#
# Workspace-wide pnpm settings (onlyBuiltDependencies, etc.) live in
# pnpm-workspace.yaml, which is where pnpm 10+ reads them.
