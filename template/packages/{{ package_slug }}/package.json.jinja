{
  "name": "{{ npm_scope }}/{{ package_slug }}",
  "version": "0.0.0+dev",
  "description": "{{ package_description }}",
  "type": "module",
  "license": "MIT",
  "author": "{{ author_name }} <{{ author_email }}>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/{{ github_owner }}/{{ github_repo_name }}.git",
    "directory": "packages/{{ package_slug }}"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  }
}
